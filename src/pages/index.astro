---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts"))
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 3);
---

<BaseLayout title="肉丸七 | Bearball Seven">
  <section class="hero">
    <p class="eyebrow">Bearball Seven</p>
    <h1>肉丸七</h1>

    <p class="lead">一隻用安靜、觀察與陪伴，慢慢說故事的小熊。</p>

    <p class="intro">
      在這裡，Bearball Seven 陪著人類走過日常，也陪著每一個正在閱讀的人，
      在忙碌與不確定之中，找到一點自己的節奏。這裡，是屬於肉丸七的小宇宙。
    </p>

    <div class="lang-divider"></div>

    <p class="lead en-lead">
      A quiet bear who tells stories through observation, presence, and gentle
      companionship.
    </p>

    <p class="intro en-intro">
      Here, Bearball Seven moves through everyday life alongside people, while
      also keeping company with each reader. In the midst of busy and uncertain
      days, this is a place to slow down and rediscover a rhythm of one’s own.
      This is the little universe of Bearball Seven.
    </p>

    <div class="hero-actions">
      <a href="/posts" class="primary-link">進入日記</a>
      <a
        href="https://www.instagram.com/bearball.seven/"
        target="_blank"
        rel="noopener noreferrer"
        class="secondary-link"
      >
        Instagram → @bearball.seven
      </a>
    </div>
  </section>

  <div class="divider"></div>

  <section class="latest">
    <div class="section-head">
      <h2>最新記事</h2>
      <a href="/posts" class="more-link">看全部文章 →</a>
    </div>

    <div class="post-list">
      {
        posts.map((post) => (
          <article class="card">
            {post.data.image && (
              <div class="protected-image">
                <img
                  src={post.data.image}
                  alt={post.data.title_zh ?? post.data.title ?? ""}
                  draggable="false"
                />
                <div class="image-shield" aria-hidden="true" />
              </div>
            )}

            <p class="meta">{post.data.date}</p>

            <h3>
              <a href={`/posts/${post.id}`}>
                {post.data.title_zh ?? post.data.title}
              </a>
            </h3>

            {post.data.title_en && <p class="title-en">{post.data.title_en}</p>}

            <div class="summary">
              <p class="summary-zh">
                {post.data.description_zh ?? post.data.description}
              </p>

              {post.data.description_en && (
                <p class="summary-en">{post.data.description_en}</p>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: 700px;
  }

  .eyebrow {
    margin: 0 0 10px;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a8a8a;
  }

  .hero h1 {
    margin: 0 0 16px;
    font-size: 3.4rem;
    line-height: 1.1;
    color: #13335f;
  }

  .lead {
    margin: 0 0 18px;
    font-size: 1.22rem;
    line-height: 1.9;
    color: #2f2f2f;
  }

  .intro {
    max-width: 640px;
    font-size: 1.05rem;
    line-height: 1.95;
    color: #4a4a4a;
  }

  .lang-divider {
    width: 100%;
    height: 1px;
    margin: 34px 0 24px;
    background: #e6e6e6;
  }

  .en-title {
    margin: 0 0 16px;
    font-size: 1.35rem;
    color: #13335f;
  }

  .en-lead,
  .en-intro {
    color: #4a4a4a;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .primary-link,
  .secondary-link {
    display: inline-block;
    padding: 10px 16px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .primary-link {
    background: #13335f;
    color: white;
  }

  .primary-link:hover {
    opacity: 0.92;
    text-decoration: none;
  }

  .secondary-link {
    background: white;
    color: #13335f;
    border: 1px solid #d8dce3;
  }

  .secondary-link:hover {
    background: #f7f9fc;
    text-decoration: none;
  }

  .divider {
    height: 1px;
    background: #e6e6e6;
    margin: 46px 0 34px;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 16px;
    margin-bottom: 20px;
  }

  .section-head h2 {
    margin: 0;
    font-size: 2rem;
    color: #13335f;
  }

  .more-link {
    font-size: 0.95rem;
    color: #13335f;
    text-decoration: none;
  }

  .more-link:hover {
    text-decoration: underline;
  }

  .post-list {
    display: grid;
    gap: 28px;
  }

  .meta {
    margin-bottom: 10px;
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    color: #999;
  }

  h3 {
    margin: 0 0 6px;
    font-size: 1.5rem;
    line-height: 1.3;
  }

  h3 a {
    color: #13335f;
    text-decoration: none;
  }

  h3 a:hover {
    text-decoration: underline;
  }

  .title-en {
    margin: 0 0 10px;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #7a7a7a;
  }

  .summary {
    color: #666;
  }

  .summary-zh {
    margin: 0;
    color: #666;
    line-height: 1.9;
  }

  .summary-en {
    margin: 6px 0 0;
    color: #8a8a8a;
    line-height: 1.8;
    font-size: 0.95em;
  }
</style>
