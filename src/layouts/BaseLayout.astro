---
const { title = "Bearball Seven" } = Astro.props;
---

<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link rel="icon" href="/favicon.ico" />

    <style>
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Noto Sans TC",
          sans-serif;
        margin: 0;
        background: #f5f5f5;
        color: #222;
      }

      nav {
        background: rgba(255, 255, 255, 0.88);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom: 1px solid #e8e8e8;
      }

      .nav-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 18px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .brand {
        color: #13335f;
        text-decoration: none;
        font-size: 1rem;
        font-weight: 700;
      }

      .nav-links {
        display: flex;
        gap: 22px;
      }

      .nav-links a {
        color: #444;
        text-decoration: none;
        font-size: 0.95rem;
      }

      .nav-links a:hover {
        color: #13335f;
      }

      main {
        max-width: 760px;
        margin: 60px auto;
        padding: 40px;
        background: #f8f8f8;
        border-radius: 16px;
      }

      a {
        color: #13335f;
        font-weight: 600;
      }

      :global(.protected-image) {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 10;
        overflow: hidden;
        border-radius: 16px;
        margin-bottom: 18px;
      }

      :global(.protected-image img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        pointer-events: none;
      }

      :global(.protected-image .image-shield) {
        position: absolute;
        inset: 0;
      }

      /* ⭐ Footer（已修正） */
      .site-footer {
        margin-top: 80px;
        padding: 40px 20px 50px;
        border-top: 1px solid #e6e6e6;
        background: #fafafa;
      }

      .footer-inner {
        max-width: 760px;
        margin: 0 auto;
        text-align: center;
      }

      .footer-brand {
        margin-bottom: 6px;
        font-weight: 700;
        color: #13335f;
      }

      .footer-desc {
        font-size: 0.95rem;
        color: #777;
        margin-bottom: 18px;
      }

      .footer-links {
        display: flex;
        justify-content: center;
        gap: 18px;
        margin-bottom: 18px;
      }

      .footer-links a {
        font-size: 0.9rem;
        color: #444;
        text-decoration: none;
      }

      .footer-links a:hover {
        color: #13335f;
      }

      .footer-copy {
        font-size: 0.8rem;
        color: #aaa;
      }

      /* ⭐ 手機版 */
      @media (max-width: 768px) {
        .nav-inner {
          padding: 16px 18px;
        }

        .nav-links {
          gap: 16px;
        }

        main {
          margin: 28px 16px;
          padding: 28px 22px;
        }
      }
    </style>
  </head>

  <body>
    <nav>
      <div class="nav-inner">
        <a href="/" class="brand">Bearball Seven</a>

        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/posts">Journal</a>
          <a href="/about">About</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-brand">Bearball Seven</p>

        <p class="footer-desc">有些故事，不急著說完。</p>

        <div class="footer-links">
          <a
            href="https://www.instagram.com/bearball.seven/"
            target="_blank"
            rel="noopener noreferrer"
          >
            Instagram
          </a>
          <a href="/about">About</a>
        </div>

        <p class="footer-copy">
          © {new Date().getFullYear()} Bearball Seven
        </p>
      </div>
    </footer>

    <script>
      document.addEventListener("contextmenu", (event) => {
        if (event.target.closest(".protected-image")) {
          event.preventDefault();
        }
      });
    </script>
  </body>
</html>
